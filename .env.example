# EDINET
EDINET_API_KEY=your_edinet_api_key

# J-Quants
JQUANTS_API_KEY=your_api_key
JQUANTS_EMAIL=your_email@example.com
JQUANTS_PASSWORD=your_password
JQUANTS_REFRESH_TOKEN=your_legacy_v1_refresh_token
# V2 uses JQUANTS_API_KEY. The legacy refresh token fields are kept for old setups.
JQUANTS_ID_TOKEN=
JQUANTS_BASE_URL=https://api.jquants.com/v2

# SEC EDGAR
SEC_USER_AGENT=ValueCatalystScreener your_email@example.com

# Price Provider
PRICE_PROVIDER=yfinance
POLYGON_API_KEY=
TIINGO_API_KEY=

# App
DB_PATH=data/value_screener.sqlite
DEFAULT_MARKET=jp
